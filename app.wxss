/* ============================================
   原来我是这种人啊 — 全局设计系统
   风格: 天蓝 · 洁白 · 可爱 · 圆润
   色调: Sky Blue + White + Sun Amber
   ============================================ */

page {
  /* === 颜色 === */
  --color-primary: #0284C7;
  --color-primary-light: #0EA5E9;
  --color-primary-soft: rgba(2, 132, 199, 0.06);
  --color-primary-glow: rgba(2, 132, 199, 0.12);

  --color-accent: #F59E0B;
  --color-accent-soft: rgba(245, 158, 11, 0.08);

  --color-bg: #F0F9FF;
  --color-bg-warm: #F5F9FC;
  --color-surface: #FFFFFF;
  --color-surface-hover: #F5FAFD;

  --color-border: #E0F0F8;
  --color-border-light: #EDF4F9;

  --text-primary: #0F172A;
  --text-secondary: #475569;
  --text-muted: #94A3B8;
  --text-subtle: #CBD5E1;
  --text-on-brand: #FFFFFF;

  /* === 间距 (4pt) === */
  --space-xs: 8rpx;
  --space-sm: 16rpx;
  --space-md: 24rpx;
  --space-lg: 32rpx;
  --space-xl: 48rpx;
  --space-2xl: 64rpx;
  --space-3xl: 96rpx;

  /* === 圆角 === */
  --radius-sm: 14rpx;
  --radius-md: 22rpx;
  --radius-lg: 30rpx;
  --radius-full: 9999rpx;

  /* === 阴影 === */
  --shadow-sm: 0 2rpx 12rpx rgba(2, 132, 199, 0.05);
  --shadow-md: 0 8rpx 28rpx rgba(2, 132, 199, 0.07);
  --shadow-lg: 0 16rpx 48rpx rgba(2, 132, 199, 0.09);
  --shadow-btn: 0 8rpx 28rpx rgba(2, 132, 199, 0.2);

  /* === 动画 === */
  --ease-out: cubic-bezier(0.16, 1, 0.3, 1);
  --ease-bounce: cubic-bezier(0.34, 1.56, 0.64, 1);
  --duration-fast: 0.15s;
  --duration-normal: 0.25s;
  --duration-slow: 0.35s;

  /* === 基础 === */
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC',
    'Helvetica Neue', 'Microsoft YaHei', sans-serif;
  color: var(--text-primary);
  background: var(--color-bg);
  -webkit-font-smoothing: antialiased;
  font-size: 28rpx;
  line-height: 1.6;
  box-sizing: border-box;
}

/* ============================================
   全局动画
   ============================================ */

@keyframes float-gentle {
  0%, 100% { transform: translateY(0); }
  50%  { transform: translateY(-14rpx); }
}

@keyframes float-wide {
  0%, 100% { transform: translate(0, 0); }
  33%  { transform: translate(16rpx, -10rpx); }
  66%  { transform: translate(-12rpx, 6rpx); }
}

@keyframes fade-in-up {
  from { opacity: 0; transform: translateY(32rpx); }
  to   { opacity: 1; transform: translateY(0); }
}

@keyframes pop-in {
  0%   { opacity: 0; transform: scale(0.88); }
  70%  { transform: scale(1.03); }
  100% { opacity: 1; transform: scale(1); }
}

@keyframes fade-in {
  from { opacity: 0; }
  to   { opacity: 1; }
}

@keyframes option-pop-in {
  0%   { opacity: 0; transform: translateX(-20rpx); }
  100% { opacity: 1; transform: translateX(0); }
}

@keyframes check-pop {
  0%   { transform: scale(0) rotate(-30deg); }
  60%  { transform: scale(1.2) rotate(5deg); }
  100% { transform: scale(1) rotate(0); }
}

@keyframes btn-breathe {
  0%, 100% { box-shadow: 0 8rpx 28rpx rgba(2, 132, 199, 0.2); }
  50%  { box-shadow: 0 8rpx 40rpx rgba(2, 132, 199, 0.3), 0 0 36rpx rgba(14, 165, 233, 0.08); }
}

@keyframes wiggle {
  0%, 100% { transform: rotate(0); }
  25%  { transform: rotate(-5deg); }
  75%  { transform: rotate(5deg); }
}

@keyframes shimmer {
  0%   { transform: translateX(-100%) skewX(-15deg); }
  100% { transform: translateX(200%) skewX(-15deg); }
}
