/* 结果页 —— 抖音/B站风：霓虹大字 + 深色卡片 + 冲屏感 */
.container { min-height: 100vh; background: #0D0D1A; padding-bottom: 120rpx; }

/* ===== 头部 —— 主播 overlay 感 ===== */
.reveal-header {
  text-align: center;
  padding: 88rpx 40rpx 72rpx;
  position: relative;
  overflow: hidden;
}

/* 大光晕背景 */
.reveal-header::before {
  content: '';
  position: absolute;
  top: -160rpx; left: 50%; transform: translateX(-50%);
  width: 500rpx; height: 500rpx;
  background: radial-gradient(circle, rgba(123,47,255,0.15) 0%, rgba(255,42,125,0.08) 50%, transparent 70%);
  border-radius: 50%;
}

.reveal-label {
  font-size: 24rpx; color: rgba(255,255,255,0.25);
  letter-spacing: 8rpx; margin-bottom: 28rpx;
  position: relative; z-index: 1;
}

/* 身份码 —— 渐变大字 */
.reveal-code {
  display: inline-block;
  font-size: 64rpx; font-weight: 900;
  color: #FF2A7D;
  letter-spacing: 14rpx;
  margin-bottom: 24rpx;
  position: relative; z-index: 1;
}

.reveal-type {
  font-size: 44rpx; font-weight: 900; color: #fff;
  margin-bottom: 20rpx; letter-spacing: 4rpx;
  position: relative; z-index: 1;
}

.reveal-oneliner {
  font-size: 26rpx; color: rgba(255,255,255,0.4);
  line-height: 1.7; padding: 0 24rpx;
  position: relative; z-index: 1;
}

.reveal-hint {
  margin-top: 44rpx; font-size: 24rpx;
  color: rgba(255,255,255,0.15); letter-spacing: 4rpx;
  position: relative; z-index: 1;
}

/* ===== 逐层揭开 —— B站卡片风 ===== */
.layers { padding: 28rpx 28rpx; }

.layer-card {
  border-radius: 24rpx; margin-bottom: 20rpx;
  overflow: hidden;
  transition: all 0.35s ease;
}

/* 已揭开 —— 深色卡 + 霓虹顶边 */
.layer-visible {
  background: #12122A;
  border: 1rpx solid rgba(255,255,255,0.04);
  position: relative;
}

/* 每张卡不同的霓虹顶线 */
.layer-visible:nth-child(1)::before {
  content: ''; position: absolute; top: 0; left: 0; right: 0; height: 4rpx;
  background: linear-gradient(90deg, transparent, #FF2A7D, transparent);
}
.layer-visible:nth-child(2)::before {
  content: ''; position: absolute; top: 0; left: 0; right: 0; height: 4rpx;
  background: linear-gradient(90deg, transparent, #00D4FF, transparent);
}
.layer-visible:nth-child(3)::before {
  content: ''; position: absolute; top: 0; left: 0; right: 0; height: 4rpx;
  background: linear-gradient(90deg, transparent, #7B2FFF, transparent);
}

.layer-content { padding: 44rpx 32rpx 40rpx; }

.layer-number {
  display: inline-block;
  font-size: 20rpx; font-weight: 700; letter-spacing: 3rpx;
  padding: 6rpx 20rpx; border-radius: 6rpx;
  margin-bottom: 16rpx;
}
.layer-visible:nth-child(1) .layer-number { background: rgba(255,42,125,0.15); color: #FF5A9E; }
.layer-visible:nth-child(2) .layer-number { background: rgba(0,212,255,0.12); color: #33D9FF; }
.layer-visible:nth-child(3) .layer-number { background: rgba(123,47,255,0.15); color: #9B5FFF; }

.layer-name { font-size: 36rpx; font-weight: 800; color: #fff; margin-bottom: 24rpx; }

.layer-match { margin-bottom: 28rpx; }
.match-badge {
  display: inline-block; padding: 6rpx 22rpx; border-radius: 6rpx;
  font-size: 22rpx; font-weight: 700;
}
.match-high { background: rgba(0,212,255,0.12); color: #33D9FF; border: 1rpx solid rgba(0,212,255,0.2); }
.match-mid { background: rgba(123,47,255,0.1); color: #9B5FFF; border: 1rpx solid rgba(123,47,255,0.15); }
.match-low { background: transparent; color: rgba(255,255,255,0.3); border: 1rpx solid rgba(255,255,255,0.08); }

.layer-analysis { font-size: 28rpx; color: rgba(255,255,255,0.6); line-height: 2; text-align: justify; }

/* 未揭开 */
.layer-hidden {
  background: #111128;
  border: 1rpx dashed rgba(255,255,255,0.06);
}
.layer-locked { padding: 56rpx 32rpx; text-align: center; }
.layer-locked:active { opacity: 0.6; transform: scale(0.97); }
.locked-icon { font-size: 32rpx; margin-bottom: 8rpx; opacity: 0.2; }
.locked-text { font-size: 28rpx; font-weight: 700; color: rgba(255,255,255,0.25); margin-bottom: 6rpx; }
.locked-hint { font-size: 24rpx; color: rgba(255,255,255,0.1); }

/* ===== 验证 ===== */
.honesty-check {
  background: #12122A; border: 1rpx solid rgba(255,255,255,0.04);
  border-radius: 24rpx; padding: 40rpx 32rpx; text-align: center;
  margin: 36rpx 28rpx 48rpx;
}
.honesty-title { font-size: 32rpx; font-weight: 800; color: #fff; margin-bottom: 16rpx; }
.honesty-body { font-size: 26rpx; color: rgba(255,255,255,0.35); line-height: 1.8; margin-bottom: 20rpx; text-align: left; }
.honesty-ask { font-size: 26rpx; color: #00D4FF; font-weight: 700; }

/* ===== 分享卡片 ===== */
.share-section { padding: 0 28rpx; margin-bottom: 40rpx; }

.share-card-preview {
  background: linear-gradient(155deg, #FF2A7D 0%, #7B2FFF 70%, #00D4FF 100%);
  border-radius: 24rpx; padding: 56rpx 36rpx; text-align: center; color: #fff;
  margin-bottom: 28rpx;
  box-shadow: 0 16rpx 48rpx rgba(255,42,125,0.2);
}
.scp-app { font-size: 20rpx; color: rgba(255,255,255,0.4); letter-spacing: 4rpx; margin-bottom: 24rpx; }
.scp-quote-highlight { font-size: 30rpx; font-weight: 700; line-height: 1.7; margin-bottom: 24rpx; }
.scp-type-tag { display: inline-block; background: rgba(255,255,255,0.15); padding: 10rpx 32rpx; border-radius: 20rpx; font-size: 24rpx; color: #fff; margin-bottom: 28rpx; }
.scp-cta { font-size: 26rpx; color: rgba(255,255,255,0.5); }

.btn-share {
  background: transparent; border: 2rpx solid #FF2A7D;
  color: #FF2A7D; border-radius: 16rpx; font-size: 32rpx; font-weight: 700; padding: 28rpx 0;
}
.btn-share:active { background: rgba(255,42,125,0.06); }

.cliffhanger { margin: 0 28rpx 40rpx; padding: 32rpx; text-align: center; }
.cliffhanger-title { font-size: 28rpx; font-weight: 700; color: rgba(255,255,255,0.25); margin-bottom: 8rpx; }
.cliffhanger-body { font-size: 26rpx; color: rgba(255,255,255,0.15); }

.retest { text-align: center; padding: 32rpx 0 80rpx; }
.btn-retest { background: none; border: none; color: rgba(255,255,255,0.12); font-size: 26rpx; }
