/* ============================================
   结果页 v2 — 命门句 + 短证据 + 矛盾钩子
   天蓝 · 洁白 · 可爱风格
   ============================================ */

.container {
  min-height: 100vh;
  background: #F0F9FF;
  padding-bottom: 120rpx;
  position: relative;
  overflow: hidden;
}

/* ---- 装饰 ---- */
.deco {
  position: absolute;
  pointer-events: none;
  z-index: 0;
  animation: float-gentle 6s ease-in-out infinite;
  will-change: transform;
}

.deco-sparkle-1 { top: 60rpx; right: 48rpx; font-size: 40rpx; animation-delay: 0s; }
.deco-sparkle-2 { top: 50%; left: 32rpx; font-size: 36rpx; animation-delay: 2s; }
.deco-sparkle-3 { bottom: 25%; right: 40rpx; font-size: 44rpx; animation-delay: 4s; }

@keyframes float-gentle {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-14rpx); }
}

@keyframes fade-in-up {
  from { opacity: 0; transform: translateY(24rpx) translateZ(0); }
  to { opacity: 1; transform: translateY(0) translateZ(0); }
}

@keyframes fade-in {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes killer-fade-1 {
  from { opacity: 0; transform: translateY(32rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes killer-fade-2 {
  0%, 30% { opacity: 0; transform: translateY(24rpx); }
  100% { opacity: 1; transform: translateY(0); }
}

@keyframes killer-fade-3 {
  0%, 50% { opacity: 0; transform: translateY(16rpx); }
  100% { opacity: 1; transform: translateY(0); }
}

@keyframes tag-fade {
  0%, 60% { opacity: 0; }
  100% { opacity: 1; }
}

/* ============================================
   第一屏：命门句
   ============================================ */
.killer-section {
  text-align: center;
  padding: 100rpx 40rpx 60rpx;
  position: relative;
  z-index: 1;
}

.killer-line {
  color: var(--text-primary);
  line-height: 1.6;
  margin-bottom: 24rpx;
}

.killer-l1 {
  font-size: 40rpx;
  font-weight: 900;
  letter-spacing: 2rpx;
  animation: killer-fade-1 0.8s ease-out both;
}

.killer-l2 {
  font-size: 32rpx;
  font-weight: 400;
  color: var(--text-secondary);
  animation: killer-fade-2 1.2s ease-out both;
}

.killer-l3 {
  font-size: 28rpx;
  color: var(--text-muted);
  line-height: 1.8;
  animation: killer-fade-3 1.6s ease-out both;
}

.killer-tag {
  display: inline-block;
  margin-top: 40rpx;
  font-size: 22rpx;
  color: var(--color-primary);
  letter-spacing: 4rpx;
  padding: 12rpx 28rpx;
  background: rgba(2, 132, 199, 0.06);
  border-radius: 100rpx;
  animation: tag-fade 2s ease-out both;
}

/* ============================================
   第二屏：3 个关键词
   ============================================ */
.keywords-section {
  padding: 0 28rpx;
  margin-bottom: 48rpx;
  position: relative;
  z-index: 1;
  animation: fade-in-up 0.6s ease-out both;
}

.keywords-label {
  text-align: center;
  font-size: 22rpx;
  color: var(--text-muted);
  letter-spacing: 4rpx;
  margin-bottom: 28rpx;
}

.keywords-row {
  display: flex;
  gap: 16rpx;
}

.keyword-card {
  flex: 1;
  background: var(--color-surface);
  border-radius: var(--radius-lg);
  padding: 28rpx 16rpx;
  text-align: center;
  box-shadow: var(--shadow-sm);
}

.kw-word {
  font-size: 28rpx;
  font-weight: 800;
  color: var(--color-primary);
  margin-bottom: 10rpx;
  padding: 8rpx 0;
  background: linear-gradient(135deg, rgba(2,132,199,0.06), rgba(14,165,233,0.04));
  border-radius: var(--radius-sm);
}

.kw-why {
  font-size: 22rpx;
  color: var(--text-muted);
  line-height: 1.5;
}

/* ============================================
   第三屏：短维度证据卡片
   ============================================ */
.evidence-section {
  padding: 0 28rpx;
  margin-bottom: 40rpx;
  position: relative;
  z-index: 1;
}

.evidence-label {
  font-size: 22rpx;
  color: var(--text-muted);
  letter-spacing: 4rpx;
  text-align: center;
  margin-bottom: 24rpx;
}

.dim-short-card {
  background: var(--color-surface);
  border-radius: var(--radius-lg);
  padding: 32rpx 28rpx 28rpx 32rpx;
  margin-bottom: 16rpx;
  border-left: 6rpx solid #0284C7;
  box-shadow: var(--shadow-sm);
  animation: fade-in-up 0.5s ease-out both;
}

.dim-short-card:nth-child(2) { animation-delay: 0.08s; border-left-color: #0EA5E9; }
.dim-short-card:nth-child(3) { animation-delay: 0.16s; border-left-color: #38BDF8; }
.dim-short-card:nth-child(4) { animation-delay: 0.24s; border-left-color: #7DD3FC; }

.ds-name {
  font-size: 20rpx;
  font-weight: 700;
  color: var(--text-muted);
  letter-spacing: 3rpx;
  margin-bottom: 16rpx;
}

.ds-zinger {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-primary);
  line-height: 1.6;
  margin-bottom: 8rpx;
}

.ds-plain {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.7;
  margin-bottom: 8rpx;
}

.ds-scene {
  font-size: 24rpx;
  color: var(--text-muted);
  line-height: 1.7;
  margin-bottom: 8rpx;
  padding-left: 16rpx;
  border-left: 2rpx solid rgba(2,132,199,0.1);
}

.ds-tease {
  font-size: 24rpx;
  color: #D97706;
  line-height: 1.6;
  font-style: italic;
  text-align: right;
  opacity: 0.85;
}

/* ============================================
   第四屏：矛盾聚光灯 — 隐藏预览
   ============================================ */
.contradiction-preview {
  margin: 0 28rpx 40rpx;
  background: linear-gradient(155deg,
    rgba(245,158,11,0.04) 0%,
    rgba(245,158,11,0.07) 50%,
    rgba(245,158,11,0.03) 100%);
  border: 2rpx solid rgba(245,158,11,0.15);
  border-radius: var(--radius-lg);
  padding: 36rpx 32rpx;
  position: relative;
  z-index: 1;
  animation: fade-in-up 0.6s ease-out 0.3s both;
}

.cp-label {
  font-size: 22rpx;
  font-weight: 700;
  color: #D97706;
  letter-spacing: 3rpx;
  margin-bottom: 20rpx;
}

.cp-evidence {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.75;
  margin-bottom: 20rpx;
  padding: 16rpx;
  background: rgba(255,255,255,0.6);
  border-radius: var(--radius-sm);
  border-left: 3rpx solid rgba(245,158,11,0.3);
}

.cp-partial {
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 1.8;
  margin-bottom: 24rpx;
  font-weight: 500;
}

.cp-unlock {
  margin-bottom: 24rpx;
}

.cp-divider {
  height: 2rpx;
  background: rgba(245,158,11,0.12);
  border-radius: 1rpx;
  margin-bottom: 12rpx;
}

.cp-unlock-text {
  font-size: 22rpx;
  color: #D97706;
  text-align: center;
  letter-spacing: 2rpx;
}

.btn-deep-read {
  background: linear-gradient(135deg, #F59E0B, #D97706);
  color: #FFF;
  border: none;
  border-radius: var(--radius-md);
  font-size: 28rpx;
  font-weight: 700;
  padding: 24rpx 0;
  box-shadow: 0 8rpx 24rpx rgba(245,158,11,0.2);
}

.btn-deep-read:active {
  transform: scale(0.97);
  opacity: 0.9;
}

/* ============================================
   第五屏：角色映射 + 分享
   ============================================ */
.outro-section {
  animation: fade-in 0.5s ease-out both;
}

/* ---- 角色映射 ---- */
.characters-section {
  margin: 40rpx 28rpx;
  padding: 40rpx 32rpx;
  background: var(--color-surface);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-md);
  position: relative; z-index: 1;
  animation: fade-in-up 0.5s ease-out both;
}

.characters-title {
  font-size: 26rpx; font-weight: 700;
  color: var(--text-muted);
  letter-spacing: 3rpx;
  margin-bottom: 32rpx; text-align: center;
}

.character-card {
  display: flex; align-items: flex-start; gap: 20rpx;
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--color-border-light);
  animation: fade-in-up 0.4s ease-out both;
}

.character-card:last-child { border-bottom: none; padding-bottom: 0; }

.character-avatar { font-size: 48rpx; flex-shrink: 0; margin-top: 4rpx; }

.character-info { flex: 1; }

.character-name {
  font-size: 32rpx; font-weight: 800; color: var(--text-primary);
  display: inline;
}

.character-source {
  display: inline-block;
  font-size: 20rpx; color: var(--text-muted);
  margin-left: 12rpx; margin-top: 4rpx;
  padding: 4rpx 16rpx;
  background: #F0F9FF; border-radius: var(--radius-full);
}

.character-reason {
  font-size: 24rpx; color: var(--text-secondary);
  line-height: 1.8; margin-top: 12rpx;
}

/* ---- 自我验证 ---- */
.honesty-check {
  background: var(--color-surface);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-md);
  padding: 44rpx 32rpx;
  text-align: center;
  margin: 0 28rpx 48rpx;
  position: relative; z-index: 1;
  animation: fade-in-up 0.5s ease-out 0.15s both;
}

.honesty-title { font-size: 34rpx; font-weight: 800; color: var(--text-primary); margin-bottom: 20rpx; }
.honesty-body { font-size: 26rpx; color: var(--text-secondary); line-height: 1.9; margin-bottom: 24rpx; text-align: left; }
.honesty-ask { font-size: 28rpx; color: #0284C7; font-weight: 700; line-height: 1.6; }

/* ---- 分享预览 ---- */
.share-section {
  padding: 0 28rpx; margin-bottom: 40rpx;
  position: relative; z-index: 1;
  animation: fade-in-up 0.5s ease-out 0.3s both;
}

.result-preview {
  background: linear-gradient(155deg, #0284C7 0%, #0EA5E9 40%, #38BDF8 70%, #7DD3FC 100%);
  border-radius: var(--radius-lg);
  padding: 56rpx 36rpx; text-align: center; color: #FFFFFF;
  margin-bottom: 28rpx;
  box-shadow: 0 16rpx 48rpx rgba(2, 132, 199, 0.25);
  position: relative; overflow: hidden;
}

.result-preview::before {
  content: '';
  position: absolute; top: -50%; left: -50%;
  width: 200%; height: 200%;
  background: radial-gradient(ellipse at 30% 20%,
    rgba(255,255,255,0.15) 0%, transparent 60%);
  pointer-events: none;
}

.scp-deco-top { font-size: 36rpx; margin-bottom: 20rpx; position: relative; z-index: 1; }

.scp-app { font-size: 20rpx; color: rgba(255,255,255,0.55); letter-spacing: 6rpx; margin-bottom: 28rpx; position: relative; z-index: 1; }
.scp-quote-highlight { font-size: 32rpx; font-weight: 700; line-height: 1.7; margin-bottom: 28rpx; position: relative; z-index: 1; }
.scp-type-tag {
  display: inline-block; background: rgba(255,255,255,0.2);
  padding: 12rpx 36rpx; border-radius: var(--radius-full);
  font-size: 24rpx; color: #FFFFFF; margin-bottom: 32rpx;
  position: relative; z-index: 1;
}
.scp-cta { font-size: 26rpx; color: rgba(255,255,255,0.6); position: relative; z-index: 1; }

/* ---- 再做一次 ---- */
.retest {
  text-align: center; padding: 32rpx 0 80rpx;
  position: relative; z-index: 1;
}

.btn-retest {
  background: none; border: none;
  color: var(--text-subtle); font-size: 26rpx;
  padding: 12rpx 32rpx;
}

.btn-retest:active { color: var(--text-muted); }

/* ---- 变化档案 ---- */
.archive-section {
  margin: 0 28rpx 40rpx;
  background: var(--color-surface);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-md);
  padding: 36rpx 32rpx;
  position: relative;
  z-index: 1;
  animation: fade-in-up 0.5s ease-out 0.4s both;
  border-left: 6rpx solid #0EA5E9;
}

.archive-label {
  font-size: 28rpx;
  font-weight: 800;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

.archive-body {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.8;
}

.archive-invite {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #0284C7;
  font-weight: 600;
  line-height: 1.6;
}

/* ============================================
   固定底栏分享
   ============================================ */
.share-bar {
  position: fixed; bottom: 0; left: 0; right: 0;
  padding: 16rpx 28rpx; padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: rgba(255,255,255,0.95);
  backdrop-filter: blur(20rpx);
  border-top: 1rpx solid #E0F0F8;
  z-index: 100;
}
.btn-share-bar {
  background: linear-gradient(135deg, #0284C7, #0EA5E9);
  color: #FFF; border: none; border-radius: var(--radius-md);
  font-size: 30rpx; font-weight: 700; padding: 24rpx 0;
  box-shadow: var(--shadow-btn);
}
.btn-share-bar:active { transform: scale(0.97); opacity: 0.92; }
