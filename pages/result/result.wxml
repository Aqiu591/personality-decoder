<!-- 结果页 — 情绪体验结构：命门句 → 关键词 → 证据 → 矛盾钩子 → 分享 -->
<view class="container" wx:if="{{result}}">
  <!-- 装饰 -->
  <view class="deco deco-sparkle-1">✨</view>
  <view class="deco deco-sparkle-2">💫</view>
  <view class="deco deco-sparkle-3">⭐</view>

  <!-- ════ 第一屏：命门句 ════ -->
  <view class="killer-section" wx:if="{{killerLine}}">
    <view class="killer-line killer-l1">{{killerLine.line1}}</view>
    <view class="killer-line killer-l2">{{killerLine.line2}}</view>
    <view class="killer-line killer-l3">{{killerLine.line3}}</view>
    <view class="killer-tag">{{killerLine.tagLine}}</view>
  </view>

  <!-- ════ 第二屏：3 个关键词 ════ -->
  <view class="keywords-section" wx:if="{{keywords.length}}">
    <view class="keywords-label">为什么是你</view>
    <view class="keywords-row">
      <view class="keyword-card" wx:for="{{keywords}}" wx:key="word">
        <view class="kw-word">{{item.word}}</view>
        <view class="kw-why">{{item.why}}</view>
      </view>
    </view>
  </view>

  <!-- ════ 第三屏：证据展示（3 个短维度） ════ -->
  <view class="evidence-section" wx:if="{{shortDimensions.length}}">
    <view class="evidence-label">📋 具体证据</view>
    <view class="dim-short-card" wx:for="{{shortDimensions}}" wx:key="name">
      <view class="ds-name">{{item.name}}</view>
      <view class="ds-zinger">{{item.zinger}}</view>
      <view class="ds-plain">{{item.plain}}</view>
      <view class="ds-scene">{{item.scene}}</view>
      <view class="ds-tease">{{item.tease}}</view>
    </view>
  </view>

  <!-- ════ 第四屏：矛盾聚光灯 ════ -->
  <view class="contradiction-preview" wx:if="{{contradictionHook}}">
    <view class="cp-label">⚡ 发现一组矛盾信号</view>
    <view class="cp-evidence">{{contradictionHook.evidence}}</view>
    <view class="cp-partial">
      <text>{{contradictionHook.partialReveal}}</text>
    </view>
    <view class="cp-unlock">
      <view class="cp-divider"></view>
      <view class="cp-unlock-text">🔮 下面把这个模式拆成 5 个生活场景</view>
    </view>
    <button class="btn-deep-read" bindtap="goReport">继续看深层解读 →</button>
  </view>

  <!-- ════ 第五屏：角色映射 + 分享 ════ -->
  <view class="outro-section">

    <!-- 角色映射 -->
    <view class="characters-section" wx:if="{{result.characters && result.characters.length}}">
      <view class="characters-title">🎬 如果在剧里，你大概是</view>
      <view class="characters-list">
        <view class="character-card" wx:for="{{result.characters}}" wx:key="name">
          <view class="character-avatar">{{index === 0 ? '🦸' : '🦹'}}</view>
          <view class="character-info">
            <view class="character-name">{{item.name}}</view>
            <view class="character-source">{{item.source}}</view>
            <view class="character-reason">{{item.reason}}</view>
          </view>
        </view>
      </view>
    </view>

    <!-- 自我验证 -->
    <view class="honesty-check">
      <view class="honesty-title">💭 说中了几条？</view>
      <view class="honesty-body">
        这不是科学鉴定，是你选的 15 道题答案指向的方向。上面这些描述——有的可能让你觉得"靠这就是我"，有的可能不太对。正常的。每个人都不一样，15 道题能画出的也只是一张比较清晰的草图。
      </view>
      <view class="honesty-ask">如果大部分说中了，分享给一个了解你的人——看 ta 怎么说。</view>
    </view>

    <!-- 分享预览卡片 -->
    <view class="share-section">
      <view class="result-preview">
        <view class="scp-deco-top">✨</view>
        <view class="scp-app">原来我是这种人啊</view>
        <view class="scp-quote-highlight">{{shareQuote}}</view>
        <view class="scp-type-tag">{{result.typeName}}</view>
        <view class="scp-cta">你也测测是哪一型 →</view>
      </view>
    </view>

    <!-- 再做一次 -->
    <view class="retest">
      <button class="btn-retest" bindtap="retest">🔄 重新测一次，看看准不准</button>
    </view>
  </view>

  <!-- 固定底栏分享 -->
  <view class="share-bar">
    <button class="btn-share-bar" open-type="share">📤 发给朋友，也测一份</button>
  </view>
</view>
