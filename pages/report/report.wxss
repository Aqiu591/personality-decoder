/* pages/report/report.wxss */
.container {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f5f5f5;
}

.placeholder {
  text-align: center;
  padding: 60rpx 40rpx;
}

.icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}

.title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a2e;
  margin-bottom: 16rpx;
}

.desc {
  font-size: 26rpx;
  color: #888;
  line-height: 1.6;
  margin-bottom: 40rpx;
}

.btn-back {
  background: #667eea;
  color: #fff;
  border: none;
  border-radius: 12rpx;
  padding: 20rpx 48rpx;
  font-size: 28rpx;
}
