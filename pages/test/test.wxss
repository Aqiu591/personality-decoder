/* ============================================
   答题页 — 白底 · 天蓝 · 圆润可爱
   ============================================ */

.container {
  min-height: 100vh;
  background: linear-gradient(180deg,
    #F0F9FF 0%,
    #E8F4FD 20%,
    #F0F9FF 50%,
    #F5FAFD 80%,
    #F0F9FF 100%);
  padding: 0 32rpx;
}

/* ---- 进度条 ---- */
.progress-section {
  padding-top: 36rpx;
  margin-bottom: 48rpx;
}

.progress-bar {
  width: 100%;
  height: 10rpx;
  background: #E0F0F8;
  border-radius: 5rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #0284C7, #0EA5E9, #38BDF8);
  border-radius: 5rpx;
  transition: width 0.4s var(--ease-out);
}

.progress-text {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 6rpx;
  font-size: 24rpx;
  color: var(--text-muted);
  margin-top: 14rpx;
  font-weight: 500;
  letter-spacing: 1rpx;
}

.progress-emoji { font-size: 22rpx; }

.progress-divider {
  color: var(--text-subtle);
  margin: 0 2rpx;
}

/* ---- 题目 ---- */
.question-card {
  animation: fade-in-up 0.4s var(--ease-out);
}

.question-number {
  display: inline-block;
  font-size: 22rpx;
  font-weight: 700;
  color: var(--color-primary);
  letter-spacing: 3rpx;
  padding: 8rpx 20rpx;
  background: var(--color-primary-soft);
  border-radius: var(--radius-full);
  margin-bottom: 20rpx;
}

.question-text {
  font-size: 40rpx;
  font-weight: 800;
  color: var(--text-primary);
  line-height: 1.4;
  margin-bottom: 56rpx;
}

/* ---- 选项 ---- */
.option {
  display: flex;
  align-items: center;
  padding: 28rpx 28rpx;
  margin-bottom: 16rpx;
  background: var(--color-surface);
  border: 2rpx solid var(--color-border-light);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
  transition: all var(--duration-normal) var(--ease-out);
  animation: option-pop-in 0.4s var(--ease-out) both;
}

.option:active {
  transform: scale(0.98);
  background: var(--color-surface-hover);
}

.option-selected {
  border-color: #0284C7;
  background: linear-gradient(135deg,
    rgba(2, 132, 199, 0.04) 0%,
    rgba(14, 165, 233, 0.04) 100%);
  box-shadow: 0 4rpx 20rpx rgba(2, 132, 199, 0.1);
}

.option-label {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: #F0F9FF;
  color: var(--text-muted);
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
  transition: all var(--duration-normal) var(--ease-out);
}

.option-selected .option-label {
  background: linear-gradient(135deg, #0284C7, #0EA5E9);
  color: #FFFFFF;
  box-shadow: 0 4rpx 16rpx rgba(2, 132, 199, 0.25);
}

.option-text {
  font-size: 30rpx;
  color: var(--text-secondary);
  line-height: 1.5;
  flex: 1;
}

.option-selected .option-text {
  color: var(--text-primary);
  font-weight: 500;
}

.option-check {
  width: 40rpx; height: 40rpx;
  border-radius: 50%;
  background: #0284C7;
  color: #FFFFFF;
  font-size: 22rpx; font-weight: 700;
  display: flex; align-items: center; justify-content: center;
  margin-left: 12rpx; flex-shrink: 0;
  animation: check-pop 0.35s var(--ease-bounce);
}

/* ---- 自定义输入 ---- */
.custom-area { margin-top: 8rpx; }

.custom-trigger {
  display: flex; align-items: center;
  padding: 24rpx 28rpx;
  border-radius: var(--radius-md);
  border: 2rpx dashed #BAE6FD;
  background: var(--color-surface);
  transition: all var(--duration-normal) var(--ease-out);
}

.custom-trigger:active {
  border-color: #0284C7;
  background: var(--color-primary-soft);
}

.custom-trigger-icon { font-size: 26rpx; color: var(--text-muted); margin-right: 12rpx; }
.custom-trigger-text { font-size: 24rpx; color: var(--text-muted); }

.custom-active {
  margin-top: 24rpx;
  animation: fade-in-up 0.3s var(--ease-out);
}

.custom-input {
  width: 100%; min-height: 140rpx;
  padding: 24rpx;
  background: var(--color-surface);
  border: 2rpx solid rgba(2, 132, 199, 0.2);
  border-radius: var(--radius-md);
  color: var(--text-primary);
  font-size: 28rpx; line-height: 1.7;
  box-sizing: border-box;
}

.custom-actions {
  display: flex; justify-content: flex-end;
  margin-top: 16rpx; gap: 16rpx;
}

.custom-btn {
  padding: 16rpx 32rpx; border-radius: var(--radius-sm);
  font-size: 24rpx; font-weight: 500;
  transition: all var(--duration-fast) var(--ease-out);
}

.custom-cancel { color: var(--text-muted); background: #F0F9FF; }
.custom-cancel:active { color: var(--text-secondary); }
.custom-confirm { color: #FFFFFF; font-weight: 700; background: #0284C7; }
.custom-confirm:active { background: #0369A1; }

/* ---- 导航 ---- */
.nav-buttons {
  display: flex; align-items: center; justify-content: space-between;
  margin-top: 48rpx; padding-top: 24rpx;
  border-top: 1rpx solid var(--color-border-light);
}

.btn-prev {
  font-size: 26rpx; color: var(--text-muted);
  padding: 16rpx 28rpx; border-radius: var(--radius-sm);
  background: #F0F9FF;
  transition: all var(--duration-fast) var(--ease-out);
}

.btn-prev:active { background: #E0F0F8; color: var(--text-secondary); }

.question-hint {
  font-size: 22rpx;
  color: var(--text-subtle);
  margin-top: -40rpx;
  margin-bottom: 32rpx;
  text-align: center;
}

.btn-next {
  font-size: 26rpx; font-weight: 600;
  color: #FFFFFF;
  padding: 16rpx 36rpx; border-radius: var(--radius-sm);
  background: linear-gradient(135deg, #0284C7, #0EA5E9);
  transition: all var(--duration-fast) var(--ease-out);
}

.btn-next:active { background: #0369A1; transform: scale(0.97); }

.option-disabled {
  opacity: 0.35;
  pointer-events: none;
}

/* ---- 完成卡 ---- */
.complete-card {
  text-align: center; padding: 160rpx 40rpx;
  animation: pop-in 0.5s var(--ease-bounce);
}

.complete-icon {
  font-size: 96rpx; margin-bottom: 28rpx;
  animation: check-pop 0.6s var(--ease-bounce) 0.2s both;
}

.complete-text {
  font-size: 44rpx; font-weight: 900; color: var(--text-primary);
  margin-bottom: 16rpx;
  animation: fade-in-up 0.5s var(--ease-out) 0.35s both;
}

.complete-desc {
  font-size: 28rpx; color: var(--text-muted); margin-bottom: 72rpx;
  animation: fade-in-up 0.5s var(--ease-out) 0.45s both;
}

.btn-view-result {
  background: linear-gradient(135deg, #0284C7, #0EA5E9, #38BDF8);
  color: #FFFFFF; border: none;
  border-radius: var(--radius-lg);
  padding: 34rpx 0; font-size: 36rpx; font-weight: 800;
  box-shadow: var(--shadow-btn);
  animation: btn-breathe 3s ease-in-out infinite, fade-in-up 0.5s var(--ease-out) 0.6s both;
}

.btn-view-result:active { transform: scale(0.97); opacity: 0.92; }
