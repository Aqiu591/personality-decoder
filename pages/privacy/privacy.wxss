/* 隐私政策 — 天蓝白统一 */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg,
    #F0F9FF 0%, #E8F4FD 30%, #F0F9FF 60%, #F5FAFD 100%);
  padding: 60rpx 36rpx 120rpx;
}

.title {
  font-size: 40rpx; font-weight: 900;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.update-date {
  font-size: 24rpx; color: var(--text-muted);
  margin-bottom: 56rpx;
}

.section {
  margin-bottom: 36rpx; padding: 32rpx;
  background: var(--color-surface);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
}

.section-title {
  font-size: 28rpx; font-weight: 700;
  color: var(--color-primary);
  margin-bottom: 16rpx;
}

.section-body {
  font-size: 26rpx; color: var(--text-secondary);
  line-height: 1.9; text-align: justify;
}

.footer {
  margin-top: 60rpx; padding-top: 32rpx;
  border-top: 1rpx solid var(--color-border-light);
  font-size: 24rpx; color: var(--text-muted);
  text-align: center;
}
