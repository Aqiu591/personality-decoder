/* 首页 —— 抖音/B站：满屏大字 + 霓虹撞色 */
.container {
  min-height: 100vh;
  background: #0D0D1A;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 0 44rpx;
  position: relative;
  overflow: hidden;
}

/* 背景光斑 */
.container::before {
  content: '';
  position: absolute;
  top: -200rpx; right: -160rpx;
  width: 500rpx; height: 500rpx;
  background: radial-gradient(circle, rgba(255,42,125,0.12) 0%, transparent 70%);
  border-radius: 50%;
}

.container::after {
  content: '';
  position: absolute;
  bottom: -120rpx; left: -120rpx;
  width: 400rpx; height: 400rpx;
  background: radial-gradient(circle, rgba(0,212,255,0.1) 0%, transparent 70%);
  border-radius: 50%;
}

.hero { width: 100%; margin-bottom: 64rpx; position: relative; z-index: 1; }

.hero-question {
  font-size: 56rpx;
  font-weight: 900;
  color: #fff;
  line-height: 1.25;
  margin-bottom: 24rpx;
}

.hero-question .highlight {
  color: #FF2A7D;
}

.hero-hint {
  font-size: 28rpx;
  color: rgba(255,255,255,0.35);
  line-height: 1.8;
}

.mirror-section { display: flex; align-items: center; width: 100%; margin-bottom: 72rpx; position: relative; z-index: 1; }
.mirror-line { flex: 1; height: 1rpx; background: rgba(255,255,255,0.06); }
.mirror-text { font-size: 24rpx; color: rgba(255,255,255,0.2); padding: 0 24rpx; letter-spacing: 1rpx; }

.cta-section { width: 100%; position: relative; z-index: 1; }

.btn-start {
  background: linear-gradient(135deg, #FF2A7D 0%, #7B2FFF 100%);
  color: #fff;
  border: none;
  border-radius: 24rpx;
  padding: 34rpx 0;
  font-size: 34rpx;
  font-weight: 800;
  width: 100%;
  letter-spacing: 2rpx;
  box-shadow: 0 8rpx 40rpx rgba(255,42,125,0.3);
}

.btn-start:active { opacity: 0.85; transform: scale(0.98); }

.footer-note { position: fixed; bottom: 52rpx; left: 44rpx; font-size: 22rpx; color: rgba(255,255,255,0.1); z-index: 1; }
