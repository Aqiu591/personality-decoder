<!-- 首页 — 天蓝 · 白云 · 可爱 -->
<view class="container">
  <!-- 装饰元素 -->
  <view class="deco-cloud cloud-1">☁️</view>
  <view class="deco-cloud cloud-2">☁️</view>
  <view class="deco-star star-1">⭐</view>
  <view class="deco-star star-2">✨</view>
  <view class="deco-bubble bubble-1"></view>
  <view class="deco-bubble bubble-2"></view>

  <!-- 主视觉 -->
  <view class="hero">
    <view class="hero-badge">🫧 原来我是这种人啊</view>
    <view class="hero-question">
      <text>你确定你</text>
      <text class="hero-highlight">了解自己</text>
      <text>吗</text>
    </view>
    <view class="hero-hint">
      <text>有些关于你的模式，别人看在眼里，</text>
      <text>你自己从来没意识到。</text>
    </view>
  </view>

  <!-- 分隔 -->
  <view class="mirror-section">
    <view class="mirror-dot">●</view>
    <view class="mirror-text">15 道情景题 · 像一面镜子</view>
    <view class="mirror-dot">●</view>
  </view>

  <!-- CTA -->
  <view class="cta-section">
    <button class="btn-start" bindtap="startTest">
      <text>看看我不知道的自己</text>
      <text class="btn-arrow">→</text>
    </button>
    <view class="cta-subtle">🛡 本地计算 · 仅供娱乐参考</view>
  </view>

  <!-- 底部 -->
  <view class="footer-note">
    <text>仅供娱乐参考，不构成测评结论或现实建议</text>
    <text class="footer-divider">·</text>
    <text class="footer-link" bindtap="goPrivacy">隐私政策</text>
  </view>
</view>
